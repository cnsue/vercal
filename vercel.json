  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!retirement-gap-calculator|pension-calc-v5|flex-pension-city-compare).*)",
      "destination": "/index.html"
    }
  ]
}
