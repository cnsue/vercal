{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "crons": [{ "path": "/api/remind", "schedule": "0 13 * * *" }],
  "rewrites": [
    {
      "source": "/((?!retirement-gap-calculator|pension-calc-v5|flex-pension-city-compare).*)",
      "destination": "/index.html"
    }
  ]
}
